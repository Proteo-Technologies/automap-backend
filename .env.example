# CSV DENUE
DATA_DIR=./DB

# CORS (frontend)
# Orígenes del frontend (CORS). Añade aquí el puerto/origen real si cambias.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# PostgreSQL (requerido para registro/login, mapas, buffers, simbología)
# Ejemplo local:
# DATABASE_URL=postgresql+asyncpg://automap:automap@localhost:5432/automap
DATABASE_URL=

# Entorno: development | staging | production (afecta validación de JWT y endurecimiento)
ENV=development

# JWT — en staging/production con DATABASE_URL: secreto ≥32 caracteres y distinto del valor por defecto
JWT_SECRET=cambiar-en-produccion-usa-secreto-largo-aleatorio

# Tras proxy que fija X-Forwarded-For de forma fiable (rate limit por IP real)
TRUSTED_PROXY=false

# Exponer /docs y OpenAPI (en producción pública suele ser false)
EXPOSE_API_DOCS=true

# HSTS (solo si la API se sirve por HTTPS detrás del proxy); 0 = desactivado
HSTS_SECONDS=0
